---
import SiteFooter from "../components/site-footer.astro";
import SiteHeader from "../components/site-header.astro";
import { formatSectionLabel, matchesRoute } from "../lib/site-shell";
import type { NoteRecord } from "../lib/notes";

interface Props {
  title: string;
  notes: NoteRecord[];
  currentRoute: string;
}

const { title, notes, currentRoute } = Astro.props;
const homeNote = notes.find((note) => note.routePath === "/");
const groupedNotes = new Map<
  string,
  {
    label: string;
    href: string;
    items: NoteRecord[];
  }
>();

for (const note of notes.filter((entry) => entry.routePath !== "/")) {
  const groupKey = note.slugSegments[0] ?? "misc";
  const existing = groupedNotes.get(groupKey) ?? {
    label: formatSectionLabel(groupKey),
    href: note.routePath,
    items: []
  };

  if (note.isDirectoryIndex && note.slugSegments.length === 1) {
    existing.label = note.title;
    existing.href = note.routePath;
  }

  existing.items.push(note);
  groupedNotes.set(groupKey, existing);
}
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | newbe-notes</title>
  </head>
  <body>
    <div class="page-shell">
      <div class="frame">
        <SiteHeader currentRoute={currentRoute} />

        <div class="content-grid">
          <aside class="sidebar" aria-label="笔记分组导航">
            <div class="sidebar-card">
              <a class:list={["home-link", currentRoute === "/" && "active"]} href="/" aria-current={currentRoute === "/" ? "page" : undefined}>
                <span class="home-label">Root note</span>
                <strong>{homeNote?.title ?? "newbe-notes"}</strong>
              </a>

              {[...groupedNotes.entries()].map(([groupName, group]) => (
                <section class="nav-group">
                  <div class="nav-group-heading">
                    <a
                      href={group.href}
                      class:list={["nav-group-link", matchesRoute(currentRoute, group.href, "prefix") && "active"]}
                      aria-current={matchesRoute(currentRoute, group.href, "prefix") ? "page" : undefined}
                    >
                      {group.label}
                    </a>
                    <span>{groupName}</span>
                  </div>
                  <div class="nav-links">
                    {group.items
                      .filter((note) => !(note.isDirectoryIndex && note.routePath === group.href))
                      .map((note) => (
                      <a
                        class:list={["nav-link", note.routePath === currentRoute && "active"]}
                        href={note.routePath}
                        aria-current={note.routePath === currentRoute ? "page" : undefined}
                      >
                        {note.title}
                      </a>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </aside>

          <main class="main">
            <slot />
          </main>
        </div>

        <SiteFooter currentRoute={currentRoute} />
      </div>
    </div>
  </body>
</html>

<style>
  :global(:root) {
    color-scheme: light;
    font-family: "Noto Serif SC", "Source Han Serif SC", Georgia, serif;
    background:
      radial-gradient(circle at top left, rgba(179, 207, 255, 0.35), transparent 28rem),
      radial-gradient(circle at right, rgba(250, 210, 162, 0.3), transparent 24rem),
      linear-gradient(180deg, #f6f1e6 0%, #efe8dc 100%);
    color: #1f1e1a;
  }

  :global(body) {
    margin: 0;
    min-height: 100vh;
  }

  .page-shell {
    min-height: 100vh;
    padding: 1.25rem;
  }

  .frame {
    display: grid;
    gap: 1.25rem;
    max-width: 94rem;
    margin: 0 auto;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(15rem, 18rem) minmax(0, 1fr);
    gap: 1.25rem;
    align-items: start;
  }

  .sidebar {
    position: sticky;
    top: 1.25rem;
  }

  .sidebar-card {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid rgba(57, 55, 48, 0.12);
    border-radius: 1.5rem;
    background: rgba(255, 250, 244, 0.82);
    box-shadow: 0 18px 42px rgba(39, 52, 93, 0.08);
    backdrop-filter: blur(14px);
  }

  .home-link,
  .nav-group-link,
  .nav-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .home-link {
    padding: 0.85rem 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.52);
    box-shadow: inset 0 0 0 1px rgba(39, 52, 93, 0.08);
  }

  .home-label,
  .nav-group-heading span {
    display: block;
    margin-bottom: 0.28rem;
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6d655d;
  }

  .nav-group {
    display: grid;
    gap: 0.55rem;
  }

  .nav-group-heading {
    display: grid;
    gap: 0.18rem;
  }

  .nav-group-link {
    font-weight: 700;
  }

  .nav-links {
    display: grid;
    gap: 0.35rem;
  }

  .nav-link {
    padding: 0.55rem 0.7rem;
    border-radius: 0.85rem;
    line-height: 1.45;
  }

  .home-link.active,
  .nav-group-link.active,
  .nav-link.active {
    background: rgba(34, 55, 96, 0.12);
    box-shadow: inset 0 0 0 1px rgba(34, 55, 96, 0.1);
  }

  .main {
    min-width: 0;
  }

  :global(.surface) {
    width: 100%;
    max-width: 58rem;
    margin: 0 auto;
    padding: 2rem 2.25rem;
    border: 1px solid rgba(39, 52, 93, 0.12);
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.74);
    box-shadow: 0 24px 60px rgba(39, 52, 93, 0.1);
    backdrop-filter: blur(10px);
  }

  :global(.eyebrow) {
    margin: 0 0 1rem;
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    font-size: 0.85rem;
    color: #6d655d;
  }

  :global(.note-body h1),
  :global(.note-body h2),
  :global(.note-body h3) {
    line-height: 1.15;
    color: #171614;
  }

  :global(.note-body p),
  :global(.note-body li) {
    font-size: 1.04rem;
    line-height: 1.8;
  }

  :global(.note-body code) {
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    font-size: 0.92em;
    padding: 0.1rem 0.28rem;
    border-radius: 0.35rem;
    background: rgba(34, 55, 96, 0.08);
  }

  :global(.note-body pre) {
    overflow-x: auto;
    padding: 1rem;
    border-radius: 1rem;
    background: #1d2433;
    color: #f5f7fb;
  }

  :global(.note-body pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  :global(.note-body a),
  :global(.article-link) {
    color: #204f99;
  }

  :global(.note-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  :global(.note-card) {
    padding: 1rem 1.1rem;
    border: 1px solid rgba(39, 52, 93, 0.12);
    border-radius: 1rem;
    background: rgba(255, 249, 241, 0.86);
  }

  :global(.note-card a) {
    color: inherit;
    text-decoration: none;
  }

  :global(.note-card p) {
    margin-bottom: 0;
  }

  :global(.section-heading) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 2rem 0 1rem;
  }

  :global(.section-heading h2) {
    margin: 0;
  }

  :global(.meta-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.85rem;
    margin-bottom: 1.5rem;
  }

  :global(.meta-card) {
    padding: 0.85rem 1rem;
    border-radius: 1rem;
    background: rgba(255, 249, 241, 0.86);
    box-shadow: inset 0 0 0 1px rgba(39, 52, 93, 0.08);
  }

  :global(.meta-card strong) {
    display: block;
    margin-bottom: 0.25rem;
  }

  @media (max-width: 900px) {
    .page-shell {
      padding: 1rem;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
    }

    .sidebar-card {
      padding: 1.1rem;
      border-radius: 1.2rem;
    }

    :global(.surface) {
      padding: 1.4rem;
      border-radius: 1.2rem;
    }
  }

  @media (max-width: 640px) {
    .page-shell {
      padding: 0.85rem;
    }

    .frame,
    .content-grid {
      gap: 1rem;
    }

    :global(.section-heading) {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
