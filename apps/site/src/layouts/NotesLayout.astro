---
import type { NoteRecord } from "../lib/notes";

interface Props {
  title: string;
  notes: NoteRecord[];
  currentRoute: string;
}

const { title, notes, currentRoute } = Astro.props;
const homeNote = notes.find((note) => note.routePath === "/");
const groupedNotes = new Map<string, NoteRecord[]>();

for (const note of notes.filter((entry) => entry.routePath !== "/")) {
  const groupName = note.slugSegments[0] ?? "misc";
  const existing = groupedNotes.get(groupName) ?? [];
  existing.push(note);
  groupedNotes.set(groupName, existing);
}
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | newbe-notes</title>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <a class:list={["home-link", currentRoute === "/" && "active"]} href="/">
          {homeNote?.title ?? "newbe-notes"}
        </a>

        {[...groupedNotes.entries()].map(([groupName, groupItems]) => (
          <section class="nav-group">
            <h2>{groupName}</h2>
            <div class="nav-links">
              {groupItems.map((note) => (
                <a
                  class:list={["nav-link", note.routePath === currentRoute && "active"]}
                  href={note.routePath}
                >
                  {note.title}
                </a>
              ))}
            </div>
          </section>
        ))}
      </aside>

      <main class="main">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  :global(:root) {
    color-scheme: light;
    font-family: "Noto Serif SC", "Source Han Serif SC", Georgia, serif;
    background:
      radial-gradient(circle at top left, rgba(179, 207, 255, 0.35), transparent 28rem),
      radial-gradient(circle at right, rgba(250, 210, 162, 0.3), transparent 24rem),
      linear-gradient(180deg, #f6f1e6 0%, #efe8dc 100%);
    color: #1f1e1a;
  }

  :global(body) {
    margin: 0;
    min-height: 100vh;
  }

  .shell {
    display: grid;
    grid-template-columns: minmax(15rem, 20rem) minmax(0, 1fr);
    min-height: 100vh;
  }

  .sidebar {
    position: sticky;
    top: 0;
    align-self: start;
    min-height: 100vh;
    padding: 2rem 1.25rem 2.5rem;
    border-right: 1px solid rgba(57, 55, 48, 0.12);
    background: rgba(255, 250, 244, 0.8);
    backdrop-filter: blur(14px);
  }

  .home-link,
  .nav-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .home-link {
    margin-bottom: 1.5rem;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .nav-group + .nav-group {
    margin-top: 1.5rem;
  }

  .nav-group h2 {
    margin: 0 0 0.65rem;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6d655d;
  }

  .nav-links {
    display: grid;
    gap: 0.35rem;
  }

  .nav-link {
    padding: 0.5rem 0.65rem;
    border-radius: 0.8rem;
    line-height: 1.35;
  }

  .active {
    background: rgba(34, 55, 96, 0.1);
    box-shadow: inset 0 0 0 1px rgba(34, 55, 96, 0.08);
  }

  .main {
    padding: 3rem 1.5rem 5rem;
  }

  :global(.surface) {
    max-width: 54rem;
    margin: 0 auto;
    padding: 2rem 2.25rem;
    border: 1px solid rgba(39, 52, 93, 0.12);
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.74);
    box-shadow: 0 24px 60px rgba(39, 52, 93, 0.1);
    backdrop-filter: blur(10px);
  }

  :global(.eyebrow) {
    margin: 0 0 1rem;
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    font-size: 0.85rem;
    color: #6d655d;
  }

  :global(.note-body h1),
  :global(.note-body h2),
  :global(.note-body h3) {
    line-height: 1.15;
    color: #171614;
  }

  :global(.note-body p),
  :global(.note-body li) {
    font-size: 1.04rem;
    line-height: 1.8;
  }

  :global(.note-body code) {
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    font-size: 0.92em;
    padding: 0.1rem 0.28rem;
    border-radius: 0.35rem;
    background: rgba(34, 55, 96, 0.08);
  }

  :global(.note-body pre) {
    overflow-x: auto;
    padding: 1rem;
    border-radius: 1rem;
    background: #1d2433;
    color: #f5f7fb;
  }

  :global(.note-body pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  :global(.note-body a) {
    color: #204f99;
  }

  :global(.note-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  :global(.note-card) {
    padding: 1rem 1.1rem;
    border: 1px solid rgba(39, 52, 93, 0.12);
    border-radius: 1rem;
    background: rgba(255, 249, 241, 0.86);
  }

  :global(.note-card a) {
    color: inherit;
    text-decoration: none;
  }

  :global(.note-card p) {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .shell {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      min-height: auto;
      border-right: 0;
      border-bottom: 1px solid rgba(57, 55, 48, 0.12);
    }

    .main {
      padding-top: 1.5rem;
    }

    :global(.surface) {
      padding: 1.4rem;
      border-radius: 1.2rem;
    }
  }
</style>

