---
import NotesLayout from "../layouts/NotesLayout.astro";
import { getAllNotes, getNoteByRoutePath } from "../lib/notes";
import { hagiCodeReferenceRoute } from "../lib/site-shell";

export async function getStaticPaths() {
  const notes = await getAllNotes();

  return notes
    .filter((note) => note.routePath !== "/")
    .map((note) => ({
      params: {
        slug: note.slugSegments.join("/")
      }
    }));
}

const slugParam = Astro.params.slug;
const slugSegments = typeof slugParam === "string" ? slugParam.split("/").filter(Boolean) : [];
const currentRoute =
  slugSegments.length === 0
    ? "/"
    : `/${slugSegments.map((segment) => encodeURIComponent(segment)).join("/")}/`;
const notes = await getAllNotes();
const note = await getNoteByRoutePath(currentRoute);

if (!note) {
  throw new Error(`No note matched route ${currentRoute}.`);
}
---

<NotesLayout title={note.title} notes={notes} currentRoute={currentRoute}>
  <section class="surface">
    <p class="eyebrow">Note detail / {currentRoute}</p>
    <div class="meta-grid">
      <div class="meta-card">
        <strong>Source</strong>
        <span>{note.sourcePath}</span>
      </div>
      <div class="meta-card">
        <strong>Route</strong>
        <span>{note.routePath}</span>
      </div>
      <div class="meta-card">
        <strong>Public HagiCode note</strong>
        <a class="article-link" href={hagiCodeReferenceRoute}>
          查看公开入口整理
        </a>
      </div>
    </div>
    <article class="note-body" set:html={note.html} />
  </section>
</NotesLayout>
