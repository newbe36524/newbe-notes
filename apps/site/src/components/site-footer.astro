---
import { getHagiCodeLinks, isLinkCurrent, siteShellMeta } from "../lib/site-shell";

interface Props {
  currentRoute: string;
}

const { currentRoute } = Astro.props;
const footerLinks = getHagiCodeLinks("footer");
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-copy">
    <p class="footer-label">newbe-notes shell</p>
    <h2>{siteShellMeta.name}</h2>
    <p>
      {siteShellMeta.summary}
      HagiCode 相关入口仅保留公开、安全、适合长期引用的链接。
    </p>
  </div>

  <div class="footer-links-block">
    <p class="footer-label">Curated HagiCode links</p>
    <div class="footer-links">
      {footerLinks.map((item) => {
        const active = isLinkCurrent(currentRoute, item);

        return (
          <a
            class:list={["footer-link", active && "active", item.external && "external"]}
            href={item.href}
            aria-current={active ? "page" : undefined}
            title={item.description}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noreferrer" : undefined}
          >
            <span class="footer-link-label">{item.label}</span>
            <span class="footer-link-description">{item.description}</span>
          </a>
        );
      })}
    </div>
  </div>

  <div class="footer-meta">
    <p class="footer-label">Ownership</p>
    <p>
      Copyright {currentYear} {siteShellMeta.owner}. This shell links only to public-safe
      destinations and the curated reference note.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.4fr) minmax(0, 0.9fr);
    gap: 1.25rem;
    padding: 1.5rem;
    border: 1px solid rgba(57, 55, 48, 0.12);
    border-radius: 1.5rem;
    background: rgba(255, 250, 244, 0.8);
    box-shadow: 0 18px 48px rgba(39, 52, 93, 0.08);
    backdrop-filter: blur(14px);
  }

  .footer-label {
    margin: 0 0 0.5rem;
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6d655d;
  }

  .footer-copy h2 {
    margin: 0;
    font-size: 1.35rem;
  }

  .footer-copy p,
  .footer-meta p {
    margin: 0.65rem 0 0;
    line-height: 1.75;
    color: #403c37;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 0.8rem;
  }

  .footer-link {
    display: grid;
    gap: 0.28rem;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.54);
    box-shadow: inset 0 0 0 1px rgba(39, 52, 93, 0.1);
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .footer-link:hover {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: inset 0 0 0 1px rgba(39, 52, 93, 0.12), 0 12px 24px rgba(39, 52, 93, 0.08);
  }

  .footer-link.active {
    background: rgba(34, 55, 96, 0.12);
    box-shadow: inset 0 0 0 1px rgba(34, 55, 96, 0.12);
  }

  .footer-link-label {
    font-weight: 700;
  }

  .footer-link-description {
    font-size: 0.92rem;
    line-height: 1.5;
    color: #59544f;
  }

  .footer-link.external .footer-link-label::after {
    content: " public";
    margin-left: 0.35rem;
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #204f99;
  }

  @media (max-width: 1050px) {
    .site-footer {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding: 1.15rem;
      border-radius: 1.2rem;
    }
  }
</style>
